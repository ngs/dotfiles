{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "WebFetch",
      "WebSearch",
      "Search",
      "Monitor"
    ],
    "ask": []
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -qE 'git[[:space:]]+(push[[:space:]](.*[[:space:]])?(--force[a-z-]*([[:space:]]|=|$)|--mirror([[:space:]]|$)|-[a-zA-Z]*f[a-zA-Z]*([[:space:]]|$))|reset[[:space:]](.*[[:space:]])?--hard([[:space:]]|$)|branch[[:space:]](.*[[:space:]])?-[a-zA-Z]*D[a-zA-Z]*([[:space:]]|$)|clean[[:space:]](.*[[:space:]])?-[a-zA-Z]*f[a-zA-Z]*([[:space:]]|$))' && { printf 'BLOCKED: destructive git command (push --force / push --mirror / reset --hard / branch -D / clean -f). Undo published commits with `git revert` instead.\\n' >&2; exit 2; } || exit 0",
            "if": "Bash(git *)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/rc.d/claude/hooks/save-prompt.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/rc.d/claude/hooks/save-response.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/dotfiles/rc.d/claude/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "firebase@firebase": true
  },
  "extraKnownMarketplaces": {
    "firebase": {
      "source": {
        "source": "github",
        "repo": "firebase/firebase-tools"
      }
    }
  },
  "language": "日本語",
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "preferredCompletionMode": "disabled"
}
